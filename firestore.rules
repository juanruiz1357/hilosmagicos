rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, email format)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (required, 'admin' | 'user')
    //   - createdAt: timestamp (optional)
    //
    // Collection: products
    // Document ID: {productId}
    // Fields:
    //   - name: string (required)
    //   - description: string (optional)
    //   - price: number (required, positive)
    //   - image: string (required, URL)
    //   - category: string (optional)
    //   - stock: number (optional, non-negative)
    //
    // Collection: orders
    // Document ID: {orderId}
    // Fields:
    //   - userId: string (required)
    //   - items: list (required)
    //   - total: number (required, positive)
    //   - status: string (required, enum)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email.lower() == "juanruiz.jr181005@gmail.com")
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.uid.size() < 128 &&
             data.email is string && data.email.size() < 256 &&
             data.role in ['admin', 'user'];
    }

    function isValidProduct(data) {
      let allowedFields = ['id', 'name', 'description', 'price', 'image', 'category', 'stock', 'rating', 'createdAt'];
      return data.keys().hasAll(['name', 'price', 'image']) &&
             data.keys().hasOnly(allowedFields) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.image is string && data.image.size() < 1000000 &&
             (!('id' in data) || data.id is string) &&
             (!('description' in data) || (data.description is string && data.description.size() < 2000)) &&
             (!('category' in data) || (data.category is string && data.category.size() < 100)) &&
             (!('stock' in data) || (data.stock is number && data.stock >= 0)) &&
             (!('rating' in data) || (data.rating is number && data.rating >= 0 && data.rating <= 5));
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'total', 'status', 'createdAt']) &&
             data.items is list &&
             data.total is number && data.total > 0 &&
             data.status in ['pending', 'shipped', 'delivered', 'cancelled'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read, write: if true; // Simplified for custom admin logic
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if true; // Simplified for custom admin logic (rocio/hilos)
    }

    match /orders/{orderId} {
      allow read: if true;
      allow create: if isValidOrder(request.resource.data);
      allow update: if true;
      allow delete: if false;
    }
  }
}
